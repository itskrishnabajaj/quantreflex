# QuantReflex Backend — Environment Variables
# Copy this file to .env and fill in actual values

# OpenAI API key (required for AI features)
OPENAI_API_KEY=sk-...

# Razorpay credentials (required for subscription payments)
# key_id is the public key (starts with rzp_live_ or rzp_test_)
RAZORPAY_KEY_ID=rzp_live_STanzIgCpSAfL7
# key_secret is the private API secret — NEVER expose this to frontend
RAZORPAY_KEY_SECRET=

# Razorpay webhook secret (required for webhook signature verification)
# Get this from Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=

# Firebase Admin SDK service account JSON (required for Auth + Firestore)
# Paste the entire JSON string from your Firebase service account key
# DO NOT store as a file — store as a single-line JSON string in this env var
FIREBASE_SERVICE_ACCOUNT=

# Server port (Render sets this automatically)
PORT=5000

# Frontend origin for CORS (comma-separated for multiple origins)
# Leave empty to allow all origins (useful for mobile-only apps)
FRONTEND_ORIGIN=
